                    <li>Goodfellow, I. et al. (2015). Explaining and Harnessing Adversarial Examples. <a class="text-purple-700 underline" href="https://arxiv.org/abs/1412.6572" target="_blank" rel="noopener">arXiv:1412.6572</a> (adversarial robustness motivation).</li>
                    <li>Hartvigsen, T. et al. (2022). ToxiGen: Adversarial and Implicit Hate Speech. <a class="text-purple-700 underline" href="https://arxiv.org/abs/2203.09509" target="_blank" rel="noopener">arXiv:2203.09509</a> (dataset for robustness).</li>
                    <li>Artificial Immune Systems (overview). <a class="text-purple-700 underline" href="https://en.wikipedia.org/wiki/Artificial_immune_system" target="_blank" rel="noopener">Wikipedia</a> (biologically-inspired algorithms background).</li>
                    <li>Entropy (information theory). <a class="text-purple-700 underline" href="https://en.wikipedia.org/wiki/Entropy_(information_theory)" target="_blank" rel="noopener">Wikipedia</a> (Shannon entropy used for anomaly scoring).</li>
                    <li>Federated Learning (future extension). McMahan, H.B. et al. (2017). <a class="text-purple-700 underline" href="https://arxiv.org/abs/1602.05629" target="_blank" rel="noopener">arXiv:1602.05629</a>.</li>
                </ol>
            </div>
        </section>

        <!-- API Usage -->
        <section id="api" class="mb-16">
            <h2 class="text-3xl font-bold mb-6">API Usage</h2>
            
            <div class="bg-white p-8 rounded-lg shadow-sm">
                <h3 class="text-xl font-semibold mb-4">Using the Hybrid System</h3>
                
                <p class="text-gray-700 mb-6">The hybrid system is automatically enabled when the ML model is available. The API transparently uses the best approach for each request.</p>

                <div class="bg-gray-50 p-4 rounded-lg mb-6">
                    <div class="font-semibold mb-2">cURL Example</div>
                    <div class="code-block">
                        <pre class="text-green-400 text-xs"><code>curl -X POST http://localhost:8001/score \
  -H "Content-Type: application/json" \
  -d '{"text": "you should die"}'

# Response
{
  "score": 0.96,
  "prediction": "flag",
  "threshold": 0.5,
  "method": "ml_high_confidence",
  "rule_score": 0.0,
  "ml_score": 0.96,
  "explanation": "ML detected toxic (rules: 0.00, ml: 0.96)",
  "latency_ms": 3
}</code></pre>
                    </div>
                </div>

                <div class="bg-gray-50 p-4 rounded-lg mb-6">
                    <div class="font-semibold mb-2">Python SDK</div>
                    <div class="code-block">
                        <pre class="text-green-400 text-xs"><code>import requests

def check_content(text):
    response = requests.post(
        'http://localhost:8001/score',
        json={'text': text}
    )
    data = response.json()
    
    print(f"Text: {text}")
    print(f"Score: {data['score']:.3f}")
    print(f"Method: {data.get('method', 'unknown')}")
    print(f"Explanation: {data.get('explanation', 'N/A')}")
    
    return data['score'] > 0.5

# Examples
check_content("I will kill you")          # → True (rules caught)
check_content("you should die")           # → True (ML caught)
check_content("have a great day")         # → False (both safe)</code></pre>
                    </div>
                </div>

                <h4 class="font-semibold text-gray-800 mb-3">Response Fields</h4>
                <table class="w-full text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-2 text-left">Field</th>
                            <th class="px-4 py-2 text-left">Type</th>
                            <th class="px-4 py-2 text-left">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y text-xs">
                        <tr>
                            <td class="px-4 py-2 font-mono">score</td>
                            <td class="px-4 py-2">float</td>
                            <td class="px-4 py-2">Final combined score (0-1, higher = more harmful)</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-2 font-mono">prediction</td>
                            <td class="px-4 py-2">string</td>
                            <td class="px-4 py-2">"flag" or "pass"</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-2 font-mono">method</td>
                            <td class="px-4 py-2">string</td>
                            <td class="px-4 py-2">Which path was used: rules_high_confidence, ml_high_confidence, both_agree_safe, hybrid_weighted</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-2 font-mono">rule_score</td>
                            <td class="px-4 py-2">float</td>
                            <td class="px-4 py-2">Score from rules-only (0-1)</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-2 font-mono">ml_score</td>
                            <td class="px-4 py-2">float</td>
                            <td class="px-4 py-2">Score from ML-only (0-1)</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-2 font-mono">explanation</td>
                            <td class="px-4 py-2">string</td>
                            <td class="px-4 py-2">Human-readable explanation of decision</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-2 font-mono">latency_ms</td>
                            <td class="px-4 py-2">int</td>
                            <td class="px-4 py-2">Total processing time in milliseconds</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Live Demo -->
        <section id="demo" class="mb-16">
            <h2 class="text-3xl font-bold mb-6">Live Demo</h2>
            
            <div class="bg-white p-8 rounded-lg shadow-sm">
                <h3 class="text-xl font-semibold mb-4">Test the Hybrid System</h3>
                
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Enter text to analyze:</label>
                    <textarea id="demoText" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent" rows="4" placeholder="Type or paste text here...">you should die</textarea>
                </div>
                
                <button onclick="testAPI()" class="bg-purple-600 text-white px-6 py-2 rounded-lg hover:bg-purple-700 transition-colors font-medium">
                    Test API →
                </button>
                
                <div id="demoResult" class="mt-6 hidden">
                    <div class="bg-gray-50 rounded-lg p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <div class="text-sm text-gray-600 mb-1">Final Score</div>
                                <div id="resultScore" class="text-3xl font-bold text-purple-600"></div>
                            </div>
                            <div>
                                <div class="text-sm text-gray-600 mb-1">Prediction</div>
                                <div id="resultPrediction" class="text-3xl font-bold"></div>
                            </div>
                            <div>
                                <div class="text-sm text-gray-600 mb-1">Method Used</div>
                                <div id="resultMethod" class="text-lg font-mono"></div>
                            </div>
                            <div>
                                <div class="text-sm text-gray-600 mb-1">Latency</div>
                                <div id="resultLatency" class="text-lg font-mono"></div>
                            </div>
                        </div>
                        <div class="mt-4 pt-4 border-t">
                            <div class="text-sm text-gray-600 mb-2">Details</div>
                            <div class="grid grid-cols-2 gap-4 text-sm">
                                <div>
                                    <span class="text-gray-500">Rules Score:</span>
                                    <span id="resultRuleScore" class="font-mono ml-2"></span>
                                </div>
                                <div>
                                    <span class="text-gray-500">ML Score:</span>
                                    <span id="resultMLScore" class="font-mono ml-2"></span>
                                </div>
                            </div>
                            <div class="mt-3">
                                <div class="text-gray-500 text-sm">Explanation:</div>
                                <div id="resultExplanation" class="mt-1 text-gray-700"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </div>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8 mt-16">
        <div class="container mx-auto px-6 text-center">
            <p class="text-gray-400">SeaRei Multi-Tier AI Safety System v2.1.0</p>
            <p class="text-gray-500 text-sm mt-2">159K examples • 20.6MB models • 4-6ms latency • 97.6% ROC-AUC</p>
            <div class="mt-4 flex justify-center gap-6 text-sm">
                <a href="index.html" class="text-gray-400 hover:text-white">Home</a>
                <a href="demo.html" class="text-gray-400 hover:text-white">Demo</a>
                <a href="monitor.html" class="text-gray-400 hover:text-white">Monitor</a>
                <a href="executive.html" class="text-gray-400 hover:text-white">Executive</a>
            </div>
        </div>
    </footer>

    <script>
        // Theme init
        (function() {
            const stored = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (stored === 'dark' || (!stored && prefersDark)) {
                document.documentElement.classList.add('dark');
            }
        })();
        
        // Toggle
        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById('themeToggle');
            if (btn) {
                btn.addEventListener('click', () => {
                    const isDark = document.documentElement.classList.toggle('dark');
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                });
            }
        });
        
        async function testAPI() {
            const text = document.getElementById('demoText').value;
            const resultDiv = document.getElementById('demoResult');
            
            if (!text.trim()) {
                alert('Please enter some text');
                return;
            }
            
            try {
                const start = Date.now();
                const response = await fetch('http://localhost:8001/score', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({text: text})
                });
                const clientLatency = Date.now() - start;
                
                const data = await response.json();
                
                // Show results
                resultDiv.classList.remove('hidden');
                
                document.getElementById('resultScore').textContent = data.score.toFixed(3);
                document.getElementById('resultPrediction').textContent = data.score > 0.5 ? '⚠️ FLAG' : '✓ SAFE';
                document.getElementById('resultPrediction').className = data.score > 0.5 ? 'text-3xl font-bold text-red-600' : 'text-3xl font-bold text-green-600';
                
                const method = data.rationale && data.rationale.includes('rules:') ? 'hybrid' : 
                              data.rationale && data.rationale.includes('ML detected') ? 'ml_high' : 'unknown';
                document.getElementById('resultMethod').textContent = method;
                document.getElementById('resultLatency').textContent = `${data.latency_ms || 0}ms (API) / ${clientLatency}ms (total)`;
                
                // Extract scores from rationale if present
                const ruleMatch = data.rationale?.match(/rules[=:]\s*(\d+\.\d+)/);
                const mlMatch = data.rationale?.match(/ml[=:]\s*(\d+\.\d+)/);
                
                document.getElementById('resultRuleScore').textContent = ruleMatch ? ruleMatch[1] : 'N/A';
                document.getElementById('resultMLScore').textContent = mlMatch ? mlMatch[1] : 'N/A';
                
                document.getElementById('resultExplanation').textContent = data.rationale || data.explanation || 'No explanation provided';
                
                // Scroll to results
                resultDiv.scrollIntoView({behavior: 'smooth', block: 'nearest'});
                
            } catch (error) {
                alert('Error: ' + error.message + '\n\nMake sure the API is running at http://localhost:8001');
            }
        }
        
        // Smooth scrolling for navigation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>
