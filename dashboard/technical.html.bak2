                            <li><strong>RAM:</strong> 512MB minimum, 1GB recommended</li>
                            <li><strong>Disk:</strong> 100MB (50MB code + 50MB models)</li>
                            <li><strong>Python:</strong> 3.9+ (tested on 3.11, 3.12, 3.13)</li>
                            <li><strong>Dependencies:</strong> scikit-learn, pandas, numpy, fastapi</li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-gray-800 mb-3">Performance Specs</h4>
                        <ul class="text-sm text-gray-600 space-y-2">
                            <li><strong>Throughput:</strong> 500+ req/sec (single core)</li>
                            <li><strong>Latency p50:</strong> 2ms</li>
                            <li><strong>Latency p95:</strong> 5ms</li>
                            <li><strong>Latency p99:</strong> 10ms</li>
                            <li><strong>Cold start:</strong> 2 seconds (model load)</li>
                        </ul>
                    </div>
                </div>

                <div class="bg-gray-50 p-4 rounded-lg">
                    <div class="font-semibold mb-2">Docker Deployment</div>
                    <div class="code-block">
                        <pre class="text-green-400 text-xs"><code># Dockerfile
FROM python:3.11-slim

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/
COPY models/ ./models/
COPY policy/ ./policy/

ENV PYTHONPATH=/app/src
CMD ["uvicorn", "service.api:app", "--host", "0.0.0.0", "--port", "8001"]

# Build & run
docker build -t searei:latest .
docker run -p 8001:8001 searei:latest</code></pre>
                    </div>
                </div>
            </div>
        </section>

