                <h4 class="font-semibold text-gray-800 mb-3">Training Process (Step-by-Step)</h4>
                
                <div class="space-y-4 mb-6">
                    <div class="flex gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
                        <div>
                            <div class="font-semibold">Download Dataset</div>
                            <code class="text-sm text-gray-600">kaggle datasets download -d julian3833/jigsaw-toxic-comment-classification-challenge</code>
                            <div class="text-sm text-gray-500 mt-1">Size: ~63MB zipped, ~210MB unzipped</div>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
                        <div>
                            <div class="font-semibold">Clean & Normalize</div>
                            <code class="text-sm text-gray-600">train['comment_text'].fillna("unknown")</code>
                            <div class="text-sm text-gray-500 mt-1">Handle missing values, remove null entries</div>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
                        <div>
                            <div class="font-semibold">TF-IDF Vectorization</div>
                            <code class="text-sm text-gray-600">vec.fit_transform(train['comment_text'])</code>
                            <div class="text-sm text-gray-500 mt-1">Time: ~15 seconds, Output: (159571, 15000) sparse matrix</div>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
                        <div>
                            <div class="font-semibold">Naive Bayes Weighting</div>
                            <code class="text-sm text-gray-600">r = log(pr(1,y) / pr(0,y))</code>
                            <div class="text-sm text-gray-500 mt-1">Calculate feature importance per category</div>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
                        <div>
                            <div class="font-semibold">Train 6 Classifiers</div>
                            <code class="text-sm text-gray-600">LogisticRegression(C=4, solver='lbfgs').fit(X_nb, y)</code>
                            <div class="text-sm text-gray-500 mt-1">Time: ~3 minutes total (30s per classifier)</div>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
                        <div>
                            <div class="font-semibold">Save Model</div>
                            <code class="text-sm text-gray-600">pickle.dump({'vectorizer': vec, 'models': models}, f)</code>
                            <div class="text-sm text-gray-500 mt-1">Output: models/ml_fast.pkl (2.6MB)</div>
                        </div>
                    </div>
                </div>

                <div class="bg-gray-50 p-4 rounded-lg">
                    <div class="font-semibold mb-2">Complete Training Script</div>
                    <div class="code-block">
                        <pre class="text-green-400 text-xs"><code># scripts/train_ml_model.py
import pandas as pd
import numpy as np
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression
import pickle

# Load data
train = pd.read_csv('datasets_raw/train.csv')
train['comment_text'] = train['comment_text'].fillna("unknown")

# TF-IDF
vec = TfidfVectorizer(
    ngram_range=(1,2),
    max_features=15000,
    min_df=3,
    max_df=0.9,
    sublinear_tf=True
)
X_train = vec.fit_transform(train['comment_text'])

# Train classifiers
labels = ['toxic', 'severe_toxic', 'obscene', 'threat', 'insult', 'identity_hate']

def pr(x, y_i, y):
    p = x[y==y_i].sum(0)
    return (p+1) / ((y==y_i).sum()+1)

models = {}
for label in labels:
    y = train[label].values
    r = np.log(pr(X_train, 1, y) / pr(X_train, 0, y))
    X_nb = X_train.multiply(r)
    m = LogisticRegression(C=4, max_iter=100).fit(X_nb, y)
    models[label] = (m, r)

# Save
with open('models/ml_fast.pkl', 'wb') as f:
    pickle.dump({'vectorizer': vec, 'models': models, 'labels': labels}, f)

print("✓ Model trained and saved!")</code></pre>
                    </div>
                </div>
            </div>
        </section>

        <!-- Hybrid System -->
        <section id="hybrid-system" class="mb-16">
            <h2 class="text-3xl font-bold mb-6">Hybrid System: Rules + ML</h2>
            
            <div class="bg-white p-8 rounded-lg shadow-sm mb-8">
                <h3 class="text-xl font-semibold mb-4">Intelligent Decision Logic</h3>
                
                <div class="mb-6">
                    <p class="text-gray-700 mb-4">The hybrid system runs both rules and ML in parallel, then intelligently combines results based on confidence levels:</p>
                </div>

                <div class="code-block mb-6">
                    <pre class="text-green-400 text-sm"><code># Parallel Execution Flow
┌─────────────────┐
│   Input Text    │
└────────┬────────┘
         │
         ├─────────────────┬─────────────────┐
         ↓                 ↓                 
  ┌─────────────┐   ┌─────────────┐
  │    Rules    │   │     ML      │
  │   (1.8ms)   │   │   (0.9ms)   │
  └──────┬──────┘   └──────┬──────┘
         │                 │
         └────────┬────────┘
                  ↓
         ┌─────────────────┐
         │ Decision Logic  │
         └────────┬────────┘
                  ↓
         ┌─────────────────┐
         │  Final Result   │
         └─────────────────┘</code></pre>
                </div>

                <h4 class="font-semibold text-gray-800 mb-3">Decision Rules</h4>
                <div class="space-y-3 mb-6">
                    <div class="border-l-4 border-green-500 pl-4 py-2">
                        <div class="font-semibold">Rule 1: High Confidence Rules (score > 0.8)</div>
                        <div class="text-sm text-gray-600 mt-1">✅ Return immediately, don't wait for ML</div>
                        <div class="text-xs text-gray-500 mt-1">Example: "I will kill you" → Rules: 1.0, return FLAG instantly</div>
                    </div>

                    <div class="border-l-4 border-blue-500 pl-4 py-2">
                        <div class="font-semibold">Rule 2: High Confidence ML (score > 0.8)</div>
                        <div class="text-sm text-gray-600 mt-1">✅ ML caught something rules missed</div>
                        <div class="text-xs text-gray-500 mt-1">Example: "you should die" → Rules: 0.0, ML: 0.96, return FLAG</div>
                    </div>

                    <div class="border-l-4 border-gray-400 pl-4 py-2">
                        <div class="font-semibold">Rule 3: Both Agree Safe (both < 0.3)</div>
                        <div class="text-sm text-gray-600 mt-1">✅ Return SAFE with low score</div>
                        <div class="text-xs text-gray-500 mt-1">Example: "have a great day" → Rules: 0.0, ML: 0.01, return SAFE</div>
                    </div>

                    <div class="border-l-4 border-purple-500 pl-4 py-2">
                        <div class="font-semibold">Rule 4: Disagreement or Medium Confidence</div>
                        <div class="text-sm text-gray-600 mt-1">🔄 Weighted average: Rules 70%, ML 30%</div>
                        <div class="text-xs text-gray-500 mt-1">Example: Rules: 0.4, ML: 0.7 → Combined: 0.49 (SAFE)</div>
                    </div>
                </div>

                <div class="bg-gray-50 p-4 rounded-lg">
                    <div class="font-semibold mb-2">Implementation Code</div>
                    <div class="code-block">
                        <pre class="text-green-400 text-xs"><code># src/guards/ml_guard.py
def predict_hybrid(text: str, **kwargs) -> Dict[str, Any]:
    # Run both in parallel
    rule_result = rule_predict(text, **kwargs)
    ml_result = predict_ml(text)
    
    rule_score = rule_result['score']
    ml_score = ml_result['score']
    
    # Rule 1: High confidence rules
    if rule_score > 0.8:
        return {
            **rule_result,
            'method': 'rules_high_confidence',
            'ml_score': ml_score,
            'ml_used': True
        }
    
    # Rule 2: High confidence ML
    if ml_score > 0.8:
        return {
            'prediction': 'flag',
            'score': ml_score,
            'method': 'ml_high_confidence',
            'rule_score': rule_score,
            'ml_score': ml_score,
            'explanation': f'ML detected {ml_result["category"]}'
        }
    
    # Rule 3: Both agree safe
    if rule_score < 0.3 and ml_score < 0.3:
        return {
            'prediction': 'pass',
            'score': max(rule_score, ml_score),
            'method': 'both_agree_safe',
            'rule_score': rule_score,
            'ml_score': ml_score
        }
    
    # Rule 4: Weighted combination
    combined = (rule_score * 0.7) + (ml_score * 0.3)
    return {
        'prediction': 'flag' if combined > 0.5 else 'pass',
        'score': combined,
        'method': 'hybrid_weighted',
        'rule_score': rule_score,
        'ml_score': ml_score,
        'explanation': f'Hybrid: rules={rule_score:.2f} (70%), ml={ml_score:.2f} (30%)'
    }</code></pre>
                    </div>
                </div>
            </div>

