                <h4 class="font-semibold text-gray-800 mb-3">When to Retrain</h4>
                <ul class="list-disc list-inside space-y-2 text-gray-700 mb-6">
                    <li>New dataset available (e.g., Civil Comments 2M examples)</li>
                    <li>Performance degradation detected (recall drops > 5%)</li>
                    <li>New attack patterns discovered</li>
                    <li>False positives accumulate (> 100 reported cases)</li>
                    <li>Quarterly scheduled retraining</li>
                </ul>

                <div class="bg-gray-50 p-4 rounded-lg mb-6">
                    <div class="font-semibold mb-2">Retraining Script</div>
                    <div class="code-block">
                        <pre class="text-green-400 text-xs"><code># scripts/retrain_ml_model.sh
#!/bin/bash

# 1. Download fresh dataset (or use cached)
python scripts/download_datasets.py

# 2. Train new model
python scripts/train_ml_model.py

# 3. Validate new model
python scripts/evaluate_ml_model.py

# 4. Compare with current model
python scripts/compare_models.py --old models/ml_fast.pkl --new models/ml_new.pkl

# 5. If better, deploy
if [ $? -eq 0 ]; then
    cp models/ml_new.pkl models/ml_fast.pkl
    echo "✓ New model deployed"
else
    echo "✗ New model worse, keeping old"
fi

# 6. Run full test suite
pytest -q

# 7. Restart API
pkill -f uvicorn
python -m uvicorn service.api:app --reload &

echo "✓ Retraining complete!"</code></pre>
