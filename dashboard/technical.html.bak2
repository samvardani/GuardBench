                            <div class="text-3xl font-bold text-purple-600">72-75%</div>
                            <div class="text-xs text-gray-600">Target Recall</div>
                        </div>
                        <div class="text-center">
                            <div class="text-3xl font-bold text-purple-600">&lt;2%</div>
                            <div class="text-xs text-gray-600">FPR Target</div>
